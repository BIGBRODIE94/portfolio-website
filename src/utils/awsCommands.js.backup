// AWS SDK v3 imports
import { EC2Client, DescribeInstancesCommand } from '@aws-sdk/client-ec2'
import { S3Client, ListBucketsCommand } from '@aws-sdk/client-s3'
import { STSClient, GetCallerIdentityCommand } from '@aws-sdk/client-sts'
import { AWS_SERVICES, COMMAND_CATEGORIES, getAllCommands, searchCommands, getServiceInfo, getServiceCommands } from './awsCommandDatabase.js'

// Store AWS credentials (these should be set by user via terminal)
let awsCredentials = {
  accessKeyId: null,
  secretAccessKey: null,
  region: 'us-east-1'
}

export const initAWS = (credentials) => {
  awsCredentials = { ...awsCredentials, ...credentials }
}

export const executeAWSCommand = async (command, term) => {
  const parts = command.toLowerCase().split(' ')
  
  // AWS CLI version
  if (command.includes('--version')) {
    term.writeln('\x1b[32maws-cli/2.13.0 Python/3.11.0 Darwin/25.0.0 source/arm64\x1b[0m')
    return
  }

  // AWS configure
  if (command.includes('configure')) {
    term.writeln('\x1b[33mвҡҷпёҸ  AWS Configuration\x1b[0m')
    term.writeln('')
    term.writeln('To connect your AWS account, you need to set up credentials:')
    term.writeln('')
    term.writeln('\x1b[36m1. Option 1: Environment Variables\x1b[0m')
    term.writeln('   export AWS_ACCESS_KEY_ID="your-access-key"')
    term.writeln('   export AWS_SECRET_ACCESS_KEY="your-secret-key"')
    term.writeln('   export AWS_DEFAULT_REGION="us-east-1"')
    term.writeln('')
    term.writeln('\x1b[36m2. Option 2: AWS CLI Configuration\x1b[0m')
    term.writeln('   Use your local AWS CLI configuration')
    term.writeln('   Credentials from ~/.aws/credentials will be used')
    term.writeln('')
    term.writeln('\x1b[36m3. Demo Mode\x1b[0m')
    term.writeln('   Currently running in demo mode with sample data')
    term.writeln('')
    term.writeln('\x1b[33mNote:\x1b[0m For security, never hardcode credentials in the browser.')
    term.writeln('Consider using AWS Cognito or temporary credentials via STS.')
    return
  }

  // AWS S3 commands
  if (command.includes('s3 ls')) {
    term.writeln('\x1b[33mрҹ“Ұ Listing S3 Buckets...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode - Showing sample buckets\x1b[0m')
      term.writeln('')
      term.writeln('2024-01-15 10:23:45 \x1b[32mcosmos-centralized-logs-production\x1b[0m')
      term.writeln('2024-02-20 14:30:12 \x1b[32mcosmos-cloudtrail-logs-428630506955\x1b[0m')
      term.writeln('2024-03-10 09:15:33 \x1b[32mcosmos-config-bucket-govcloud\x1b[0m')
      term.writeln('2024-04-05 16:45:21 \x1b[32mcosmos-wiz-sensor-configs\x1b[0m')
      term.writeln('2023-12-01 11:20:55 \x1b[32mvdmstest-firehose-logs\x1b[0m')
      term.writeln('')
      term.writeln('\x1b[36mрҹ’Ў Tip: Run "aws configure" to set up real AWS credentials\x1b[0m')
      return
    }

    try {
      const s3Client = new S3Client({
        region: awsCredentials.region,
        credentials: {
          accessKeyId: awsCredentials.accessKeyId,
          secretAccessKey: awsCredentials.secretAccessKey
        }
      })

      const data = await s3Client.send(new ListBucketsCommand({}))
      
      if (data.Buckets && data.Buckets.length > 0) {
        data.Buckets.forEach(bucket => {
          const date = bucket.CreationDate.toISOString().split('T')[0]
          term.writeln(`${date} \x1b[32m${bucket.Name}\x1b[0m`)
        })
      } else {
        term.writeln('\x1b[33mNo buckets found\x1b[0m')
      }
    } catch (error) {
      term.writeln(`\x1b[31mвқҢ Error: ${error.message}\x1b[0m`)
      term.writeln('\x1b[33mFalling back to demo mode...\x1b[0m')
    }
    return
  }

  // AWS EC2 commands
  if (command.includes('ec2 describe-instances')) {
    term.writeln('\x1b[33mрҹ–ҘпёҸ  Listing EC2 Instances...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode - Showing sample instances\x1b[0m')
      term.writeln('')
      term.writeln('в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ')
      term.writeln('в”Ӯ Instance ID         в”Ӯ Type         в”Ӯ State       в”Ӯ Name       в”Ӯ')
      term.writeln('в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө')
      term.writeln('в”Ӯ \x1b[36mi-011f307ce94bc8f98\x1b[0m в”Ӯ t3.medium    в”Ӯ \x1b[32mrunning\x1b[0m     в”Ӯ Web-Server в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mi-086230c5a494562fe\x1b[0m в”Ӯ t3.large     в”Ӯ \x1b[32mrunning\x1b[0m     в”Ӯ App-Server в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mi-0a3b4c5d6e7f8g9h0\x1b[0m в”Ӯ t3.xlarge    в”Ӯ \x1b[32mrunning\x1b[0m     в”Ӯ DB-Server  в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mi-0b4c5d6e7f8g9h0a1\x1b[0m в”Ӯ t3.small     в”Ӯ \x1b[33mstopped\x1b[0m     в”Ӯ Test-Srv   в”Ӯ')
      term.writeln('в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ')
      term.writeln('')
      term.writeln('\x1b[36mрҹ’Ў Tip: Run "aws configure" to set up real AWS credentials\x1b[0m')
      return
    }

    try {
      const ec2Client = new EC2Client({
        region: awsCredentials.region,
        credentials: {
          accessKeyId: awsCredentials.accessKeyId,
          secretAccessKey: awsCredentials.secretAccessKey
        }
      })

      const data = await ec2Client.send(new DescribeInstancesCommand({}))
      
      if (data.Reservations && data.Reservations.length > 0) {
        data.Reservations.forEach(reservation => {
          reservation.Instances.forEach(instance => {
            const name = instance.Tags?.find(tag => tag.Key === 'Name')?.Value || 'N/A'
            term.writeln(`\x1b[36m${instance.InstanceId}\x1b[0m | ${instance.InstanceType} | \x1b[32m${instance.State.Name}\x1b[0m | ${name}`)
          })
        })
      } else {
        term.writeln('\x1b[33mNo instances found\x1b[0m')
      }
    } catch (error) {
      term.writeln(`\x1b[31mвқҢ Error: ${error.message}\x1b[0m`)
    }
    return
  }

  // AWS STS get-caller-identity
  if (command.includes('sts get-caller-identity')) {
    term.writeln('\x1b[33mрҹ”җ Getting AWS Identity...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode\x1b[0m')
      term.writeln('{')
      term.writeln('  "UserId": "AIDACKCEVSQ6C2EXAMPLE",')
      term.writeln('  "Account": "428630506955",')
      term.writeln('  "Arn": "arn:aws:iam::428630506955:user/affan-chowdhury"')
      term.writeln('}')
      return
    }

    try {
      const stsClient = new STSClient({
        region: awsCredentials.region,
        credentials: {
          accessKeyId: awsCredentials.accessKeyId,
          secretAccessKey: awsCredentials.secretAccessKey
        }
      })

      const data = await stsClient.send(new GetCallerIdentityCommand({}))
      term.writeln(JSON.stringify(data, null, 2))
    } catch (error) {
      term.writeln(`\x1b[31mвқҢ Error: ${error.message}\x1b[0m`)
    }
    return
  }

  // AWS IAM commands
  if (command.includes('iam list-users')) {
    term.writeln('\x1b[33mрҹ‘Ҙ Listing IAM Users...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode - Showing sample users\x1b[0m')
      term.writeln('')
      term.writeln('в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ')
      term.writeln('в”Ӯ User Name           в”Ӯ Create Date                  в”Ӯ Password Last   в”Ӯ')
      term.writeln('в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө')
      term.writeln('в”Ӯ \x1b[36maffan-chowdhury\x1b[0m     в”Ӯ 2023-01-15T10:30:00Z        в”Ӯ 2024-01-10      в”Ӯ')
      term.writeln('в”Ӯ \x1b[36madmin-user\x1b[0m         в”Ӯ 2023-02-20T14:15:00Z        в”Ӯ 2024-01-05      в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mdev-user\x1b[0m           в”Ӯ 2023-03-10T09:45:00Z        в”Ӯ 2024-01-08      в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mci-cd-user\x1b[0m         в”Ӯ 2023-04-05T16:20:00Z        в”Ӯ Never           в”Ӯ')
      term.writeln('в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ')
      term.writeln('')
      term.writeln('\x1b[36mрҹ’Ў Tip: Run "aws configure" to set up real AWS credentials\x1b[0m')
    }
    return
  }

  // AWS CloudWatch commands
  if (command.includes('cloudwatch list-metrics')) {
    term.writeln('\x1b[33mрҹ“Ҡ Listing CloudWatch Metrics...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode - Showing sample metrics\x1b[0m')
      term.writeln('')
      term.writeln('в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ')
      term.writeln('в”Ӯ Namespace           в”Ӯ Metric Name          в”Ӯ Dimensions          в”Ӯ')
      term.writeln('в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө')
      term.writeln('в”Ӯ \x1b[36mAWS/EC2\x1b[0m              в”Ӯ CPUUtilization       в”Ӯ InstanceId=i-xxx   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mAWS/EC2\x1b[0m              в”Ӯ NetworkIn            в”Ӯ InstanceId=i-xxx   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mAWS/EC2\x1b[0m              в”Ӯ NetworkOut           в”Ӯ InstanceId=i-xxx   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mAWS/EC2\x1b[0m              в”Ӯ DiskReadOps          в”Ӯ InstanceId=i-xxx   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mAWS/S3\x1b[0m               в”Ӯ BucketSizeBytes      в”Ӯ BucketName=xxx     в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mAWS/S3\x1b[0m               в”Ӯ NumberOfObjects      в”Ӯ BucketName=xxx     в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mAWS/Lambda\x1b[0m           в”Ӯ Duration             в”Ӯ FunctionName=xxx   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mAWS/Lambda\x1b[0m           в”Ӯ Invocations          в”Ӯ FunctionName=xxx   в”Ӯ')
      term.writeln('в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ')
      term.writeln('')
      term.writeln('\x1b[36mрҹ’Ў Tip: Run "aws configure" to set up real AWS credentials\x1b[0m')
    }
    return
  }

  // AWS Lambda commands
  if (command.includes('lambda list-functions')) {
    term.writeln('\x1b[33mвҡЎ Listing Lambda Functions...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode - Showing sample functions\x1b[0m')
      term.writeln('')
      term.writeln('в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ')
      term.writeln('в”Ӯ Function Name       в”Ӯ Runtime             в”Ӯ Code Size           в”Ӯ Last Modifiedв”Ӯ')
      term.writeln('в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө')
      term.writeln('в”Ӯ \x1b[36mhello-world\x1b[0m          в”Ӯ python3.9            в”Ӯ 1024 bytes         в”Ӯ 2024-01-15   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mapi-handler\x1b[0m          в”Ӯ nodejs18.x            в”Ӯ 2048 bytes         в”Ӯ 2024-01-14   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mdata-processor\x1b[0m       в”Ӯ python3.9            в”Ӯ 4096 bytes         в”Ӯ 2024-01-13   в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mnotification-sender\x1b[0m  в”Ӯ nodejs18.x            в”Ӯ 1536 bytes         в”Ӯ 2024-01-12   в”Ӯ')
      term.writeln('в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ')
      term.writeln('')
      term.writeln('\x1b[36mрҹ’Ў Tip: Run "aws configure" to set up real AWS credentials\x1b[0m')
    }
    return
  }

  // AWS RDS commands
  if (command.includes('rds describe-db-instances')) {
    term.writeln('\x1b[33mрҹ—„пёҸ  Listing RDS Instances...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode - Showing sample RDS instances\x1b[0m')
      term.writeln('')
      term.writeln('в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ')
      term.writeln('в”Ӯ DB Instance ID      в”Ӯ Engine      в”Ӯ Status      в”Ӯ Endpoint        в”Ӯ')
      term.writeln('в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө')
      term.writeln('в”Ӯ \x1b[36mprod-database\x1b[0m        в”Ӯ mysql       в”Ӯ \x1b[32mavailable\x1b[0m     в”Ӯ prod-db.xxx.com в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mstaging-database\x1b[0m     в”Ӯ postgres    в”Ӯ \x1b[32mavailable\x1b[0m     в”Ӯ staging.xxx.com в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mtest-database\x1b[0m        в”Ӯ mysql       в”Ӯ \x1b[33mstopped\x1b[0m       в”Ӯ test.xxx.com    в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mdev-database\x1b[0m         в”Ӯ postgres    в”Ӯ \x1b[32mavailable\x1b[0m     в”Ӯ dev.xxx.com     в”Ӯ')
      term.writeln('в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ')
      term.writeln('')
      term.writeln('\x1b[36mрҹ’Ў Tip: Run "aws configure" to set up real AWS credentials\x1b[0m')
    }
    return
  }

  // AWS VPC commands
  if (command.includes('vpc describe-vpcs')) {
    term.writeln('\x1b[33mрҹҢҗ Listing VPCs...\x1b[0m')
    term.writeln('')
    
    if (!awsCredentials.accessKeyId) {
      term.writeln('\x1b[33mвҡ пёҸ  Demo Mode - Showing sample VPCs\x1b[0m')
      term.writeln('')
      term.writeln('в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ')
      term.writeln('в”Ӯ VpcId               в”Ӯ State               в”Ӯ CidrBlock           в”Ӯ Name        в”Ӯ')
      term.writeln('в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө')
      term.writeln('в”Ӯ \x1b[36mvpc-1234567890abcdef0\x1b[0m в”Ӯ \x1b[32mavailable\x1b[0m         в”Ӯ 10.0.0.0/16        в”Ӯ Production  в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mvpc-0987654321fedcba0\x1b[0m в”Ӯ \x1b[32mavailable\x1b[0m         в”Ӯ 10.1.0.0/16        в”Ӯ Staging     в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mvpc-abcdef1234567890\x1b[0m  в”Ӯ \x1b[32mavailable\x1b[0m         в”Ӯ 10.2.0.0/16        в”Ӯ Development в”Ӯ')
      term.writeln('в”Ӯ \x1b[36mvpc-fedcba0987654321\x1b[0m  в”Ӯ \x1b[32mavailable\x1b[0m         в”Ӯ 172.16.0.0/16      в”Ӯ Testing     в”Ӯ')
      term.writeln('в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ')
      term.writeln('')
      term.writeln('\x1b[36mрҹ’Ў Tip: Run "aws configure" to set up real AWS credentials\x1b[0m')
    }
    return
  }

  // AWS help command with comprehensive service listing
  if (command.includes('help')) {
    showAWSHelp(term, command)
    return
  }

  // AWS services command - list all services
  if (command === 'aws services' || command === 'aws list-services') {
    showAWSServices(term)
    return
  }

  // AWS search command - search for specific commands
  if (command.startsWith('aws search')) {
    const searchTerm = command.replace('aws search', '').trim()
    if (searchTerm) {
      showCommandSearch(term, searchTerm)
    } else {
      term.writeln('\x1b[31mвқҢ Please provide a search term: aws search <term>\x1b[0m')
    }
    return
  }

  // AWS service commands - show commands for a specific service
  if (command.startsWith('aws ') && !command.includes(' ')) {
    const serviceName = command.replace('aws ', '').trim()
    showServiceCommands(term, serviceName)
    return
  }

  // Default AWS help
  showAWSHelp(term)
}

// Enhanced AWS Help function
const showAWSHelp = (term, command = '') => {
  term.writeln('\x1b[33mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\x1b[0m')
  term.writeln('\x1b[33mв•‘              AWS CLI Command Reference v2.0                  в•‘\x1b[0m')
  term.writeln('\x1b[33mв•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\x1b[0m')
  term.writeln('')
  term.writeln('\x1b[1;36mAvailable AWS CLI Commands:\x1b[0m')
  term.writeln('')
  term.writeln('  \x1b[32maws --version\x1b[0m              - Show AWS CLI version')
  term.writeln('  \x1b[32maws configure\x1b[0m              - Configure AWS credentials')
  term.writeln('  \x1b[32maws services\x1b[0m               - List all AWS services')
  term.writeln('  \x1b[32maws search <term>\x1b[0m          - Search commands by keyword')
  term.writeln('  \x1b[32maws <service>\x1b[0m              - Show commands for specific service')
  term.writeln('')
  term.writeln('\x1b[1;33mPopular Commands:\x1b[0m')
  term.writeln('  \x1b[32maws s3 ls\x1b[0m                  - List S3 buckets')
  term.writeln('  \x1b[32maws ec2 describe-instances\x1b[0m - List EC2 instances')
  term.writeln('  \x1b[32maws sts get-caller-identity\x1b[0m - Get AWS account info')
  term.writeln('  \x1b[32maws iam list-users\x1b[0m        - List IAM users')
  term.writeln('  \x1b[32maws cloudwatch list-metrics\x1b[0m - List CloudWatch metrics')
  term.writeln('')
  term.writeln('\x1b[1;35mService Categories:\x1b[0m')
  term.writeln('  \x1b[36mCompute:\x1b[0m EC2, ECS, EKS, Lambda')
  term.writeln('  \x1b[36mStorage:\x1b[0m S3, EFS')
  term.writeln('  \x1b[36mDatabase:\x1b[0m RDS, DynamoDB')
  term.writeln('  \x1b[36mNetworking:\x1b[0m VPC, CloudFront')
  term.writeln('  \x1b[36mSecurity:\x1b[0m IAM, KMS, Secrets Manager')
  term.writeln('  \x1b[36mMonitoring:\x1b[0m CloudWatch, CloudTrail')
  term.writeln('')
  term.writeln('\x1b[36mрҹ’Ў Try: aws services, aws search ec2, aws s3\x1b[0m')
  term.writeln('\x1b[33mвҡ пёҸ  Currently in demo mode. Set up credentials to use real AWS commands.\x1b[0m')
}

// Show all AWS services
const showAWSServices = (term) => {
  term.writeln('\x1b[33mрҹ“Ӣ AWS Services Available in This Terminal:\x1b[0m')
  term.writeln('')
  
  Object.entries(COMMAND_CATEGORIES).forEach(([category, services]) => {
    term.writeln(`\x1b[1;36m${category.toUpperCase()}:\x1b[0m`)
    services.forEach(service => {
      const serviceInfo = AWS_SERVICES[service]
      if (serviceInfo) {
        term.writeln(`  \x1b[32m${service.padEnd(15)}\x1b[0m - ${serviceInfo.description}`)
      }
    })
    term.writeln('')
  })
  
  term.writeln('\x1b[36mрҹ’Ў Use "aws <service>" to see commands for a specific service\x1b[0m')
  term.writeln('\x1b[36mрҹ’Ў Example: aws ec2, aws s3, aws iam\x1b[0m')
}

// Show commands for a specific service
const showServiceCommands = (term, serviceName) => {
  const serviceInfo = getServiceInfo(serviceName)
  
  if (!serviceInfo) {
    term.writeln(`\x1b[31mвқҢ Service '${serviceName}' not found\x1b[0m`)
    term.writeln('\x1b[33mрҹ’Ў Use "aws services" to see all available services\x1b[0m')
    return
  }
  
  term.writeln(`\x1b[33mрҹ”§ ${serviceInfo.name} (${serviceName.toUpperCase()})\x1b[0m`)
  term.writeln(`\x1b[36m${serviceInfo.description}\x1b[0m`)
  term.writeln('')
  term.writeln('\x1b[1;32mAvailable Commands:\x1b[0m')
  
  // Group commands by category for better readability
  const commands = serviceInfo.commands
  const chunkSize = 3
  for (let i = 0; i < commands.length; i += chunkSize) {
    const chunk = commands.slice(i, i + chunkSize)
    const commandLine = chunk.map(cmd => `\x1b[32maws ${serviceName} ${cmd}\x1b[0m`).join(' | ')
    term.writeln(`  ${commandLine}`)
  }
  
  term.writeln('')
  term.writeln('\x1b[36mрҹ’Ў Example: aws ' + serviceName + ' ' + commands[0] + '\x1b[0m')
}

// Search commands by keyword
const showCommandSearch = (term, searchTerm) => {
  term.writeln(`\x1b[33mрҹ”Қ Searching for: "${searchTerm}"\x1b[0m`)
  term.writeln('')
  
  const results = searchCommands(searchTerm)
  
  if (results.length === 0) {
    term.writeln('\x1b[31mвқҢ No commands found matching your search\x1b[0m')
    term.writeln('\x1b[33mрҹ’Ў Try different keywords or use "aws services" to browse\x1b[0m')
    return
  }
  
  results.forEach(({ service, info, commands }) => {
    term.writeln(`\x1b[1;32m${info.name} (${service.toUpperCase()}):\x1b[0m`)
    term.writeln(`\x1b[36m${info.description}\x1b[0m`)
    commands.forEach(cmd => {
      term.writeln(`  \x1b[32maws ${service} ${cmd}\x1b[0m`)
    })
    term.writeln('')
  })
  
  term.writeln(`\x1b[36mрҹ’Ў Found ${results.length} service(s) with matching commands\x1b[0m')
}

